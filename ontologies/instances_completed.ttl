    ex:officialAccessibilityStatus "Full wheelchair access"^^xsd:string ;
    ex:servedByLine inst:northern ;
    ex:stationHasAccessibilityAssessment inst:Accessibility_940GZZLUFYC ;
    ex:stationName "Finchley Central"^^xsd:string .

inst:940GZZLUKNG a ex:UndergroundStation ;
