    ex:hasLift false ;
    ex:isFullyWheelchairAccessible false ;
    ex:officialAccessibilityStatus "No step-free access"^^xsd:string ;
    ex:stepFreeToPlatform false ;
    ex:stepFreeToStreet false ;
    ex:stepFreeToVehicle false ;
